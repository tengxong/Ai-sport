# Database Configuration
# Copy this file to .env and fill in your actual values
# .env is ignored by git for security

DB_NAME=aiSport
DB_USER=postgres
DB_PASSWORD=12345
DB_HOST=localhost
DB_PORT=5432

# Optional: S3 storage for uploaded images (product/profile/contact)
# Set S3_ENABLED=true and fill the values below when deploying
S3_ENABLED=false
S3_BUCKET_NAME=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional (S3-compatible providers): e.g. https://<account>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=
# Optional public URL base to serve files (recommended when using CDN/custom domain)
# Example: https://cdn.example.com/uploads
S3_PUBLIC_BASE_URL=
# Object prefix in bucket (default: uploads)
S3_OBJECT_PREFIX=uploads

# Flask Secret Key (generate a random string)
SECRET_KEY=1234567890
